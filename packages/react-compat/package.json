{
  "name": "what-react",
  "version": "0.11.6",
  "description": "React compatibility layer for What Framework — real React semantics (value hooks, re-renders, context) on a dedicated compat runtime",
  "type": "module",
  "sideEffects": false,
  "main": "src/index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "node --test 'test/*.test.js'"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js",
      "default": "./src/index.js"
    },
    "./dom": {
      "types": "./dom.d.ts",
      "import": "./src/dom.js",
      "default": "./src/dom.js"
    },
    "./jsx-runtime": {
      "types": "./jsx-runtime.d.ts",
      "import": "./src/jsx-runtime.js",
      "default": "./src/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "types": "./jsx-dev-runtime.d.ts",
      "import": "./src/jsx-dev-runtime.js",
      "default": "./src/jsx-dev-runtime.js"
    },
    "./vite": {
      "types": "./vite.d.ts",
      "import": "./src/vite-plugin.js",
      "default": "./src/vite-plugin.js"
    }
  },
  "files": [
    "src",
    "index.d.ts",
    "dom.d.ts",
    "jsx-runtime.d.ts",
    "jsx-dev-runtime.d.ts",
    "vite.d.ts"
  ],
  "keywords": [
    "react",
    "compat",
    "what",
    "framework",
    "signals",
    "compatibility"
  ],
  "peerDependencies": {
    "what-core": "^0.11.6"
  },
  "author": "ZVN DEV (https://zvndev.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CelsianJs/what-framework"
  },
  "bugs": {
    "url": "https://github.com/CelsianJs/what-framework/issues"
  },
  "homepage": "https://react.whatfw.com"
}
