{
  "name": "what-compiler",
  "version": "0.6.2",
  "description": "JSX compiler for What Framework - transforms JSX to optimized DOM operations",
  "main": "src/index.js",
  "type": "module",
  "exports": {
    ".": {
      "production": "./dist/index.min.js",
      "import": "./src/index.js"
    },
    "./babel": {
      "production": "./dist/babel-plugin.min.js",
      "import": "./src/babel-plugin.js"
    },
    "./vite": {
      "production": "./dist/vite-plugin.min.js",
      "import": "./src/vite-plugin.js"
    },
    "./runtime": {
      "production": "./dist/runtime.min.js",
      "import": "./src/runtime.js"
    },
    "./file-router": {
      "production": "./dist/file-router.min.js",
      "import": "./src/file-router.js"
    }
  },
  "keywords": [
    "what",
    "framework",
    "compiler",
    "jsx",
    "babel",
    "vite"
  ],
  "author": "ZVN DEV (https://zvndev.com)",
  "license": "MIT",
  "peerDependencies": {
    "@babel/core": "^7.0.0",
    "what-core": "^0.6.0"
  },
  "files": [
    "src",
    "dist"
  ],
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CelsianJs/what-framework"
  },
  "bugs": {
    "url": "https://github.com/CelsianJs/what-framework/issues"
  },
  "homepage": "https://whatfw.com"
}
