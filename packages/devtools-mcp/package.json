{
  "name": "what-devtools-mcp",
  "version": "0.6.5",
  "description": "MCP server bridging AI agents to live What Framework app state via WebSocket",
  "type": "module",
  "bin": {
    "what-devtools-mcp": "src/index.js"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/index.js"
    },
    "./client": {
      "types": "./client.d.ts",
      "import": "./src/client.js"
    },
    "./vite-plugin": {
      "types": "./vite-plugin.d.ts",
      "import": "./src/vite-plugin.js"
    }
  },
  "files": [
    "src",
    "index.d.ts",
    "client.d.ts",
    "vite-plugin.d.ts"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ws": "^8.0.0",
    "zod": "^3.25.0"
  },
  "peerDependencies": {
    "what-devtools": "^0.6.5"
  },
  "keywords": [
    "what-framework",
    "devtools",
    "mcp",
    "model-context-protocol",
    "ai-debugging"
  ],
  "license": "MIT",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/CelsianJs/what-framework"
  },
  "homepage": "https://whatfw.com",
  "bugs": {
    "url": "https://github.com/CelsianJs/what-framework/issues"
  }
}
