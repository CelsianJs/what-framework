{
  "name": "what-framework",
  "version": "0.6.0",
  "description": "The closest framework to vanilla JS — signals, components, islands, SSR",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "production": "./dist/index.min.js",
      "import": "./src/index.js"
    },
    "./jsx-runtime": {
      "production": "./dist/jsx-runtime.min.js",
      "import": "./src/jsx-runtime.js"
    },
    "./jsx-dev-runtime": {
      "production": "./dist/jsx-dev-runtime.min.js",
      "import": "./src/jsx-dev-runtime.js"
    },
    "./router": {
      "types": "./router.d.ts",
      "production": "./dist/router.min.js",
      "import": "./src/router.js"
    },
    "./server": {
      "types": "./server.d.ts",
      "production": "./dist/server.min.js",
      "import": "./src/server.js"
    },
    "./render": {
      "types": "./render.d.ts",
      "production": "./dist/render.min.js",
      "import": "./src/render.js"
    },
    "./testing": {
      "types": "./testing.d.ts",
      "production": "./dist/testing.min.js",
      "import": "./src/testing.js"
    }
  },
  "files": [
    "src",
    "dist",
    "index.d.ts",
    "render.d.ts",
    "router.d.ts",
    "server.d.ts",
    "testing.d.ts"
  ],
  "sideEffects": false,
  "keywords": [
    "framework",
    "signals",
    "reactive",
    "islands",
    "ssr",
    "vanilla-js",
    "lightweight",
    "router",
    "components"
  ],
  "author": "ZVN DEV (https://zvndev.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CelsianJs/what-framework"
  },
  "bugs": {
    "url": "https://github.com/CelsianJs/what-framework/issues"
  },
  "homepage": "https://whatfw.com",
  "dependencies": {
    "what-core": "^0.6.0",
    "what-router": "^0.6.0",
    "what-server": "^0.6.0",
    "what-compiler": "^0.6.0"
  }
}
